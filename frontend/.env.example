# Copy this file to .env (or .env.local) for local development, and set
# VITE_HF_SPACE_URL in Vercel's project env vars for the deployed build.

# Base URL of the backend API (the FastAPI Docker Space). No trailing slash.
# Example: https://your-username-your-space.hf.space
VITE_HF_SPACE_URL=http://127.0.0.1:8000
